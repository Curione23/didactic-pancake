<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollContentBrowserRoot"
    android:background="?android:attr/colorBackground"
    android:paddingTop="8dp"
    android:paddingBottom="10dp"
    android:focusableInTouchMode="true"
    android:clipToPadding="false"
    android:descendantFocusability="beforeDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/layoutContentBrowserHeader"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">
                <ImageView
                    android:id="@+id/imageContentBrowserInstanceIcon"
                    android:background="@drawable/bg_content_browser_instance_icon"
                    android:padding="3dp"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/content_browser_instance_icon_description"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:id="@+id/textContentBrowserInstanceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="1"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:ellipsize="end"
                        android:id="@+id/textContentBrowserInstanceMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBackToInstance"
                    android:padding="0dp"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:minWidth="42dp"
                    android:minHeight="42dp"
                    android:contentDescription="@string/content_browser_back_to_instance"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_arrow_back_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold"
            android:id="@+id/textContentBrowserTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/content_browser_install_title"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleContentSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/buttonSourceModrinth"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:minHeight="40dp"
                android:text="@string/content_browser_source_modrinth"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/buttonSourceCurseForge"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:minHeight="40dp"
                android:text="@string/content_browser_source_curseforge"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
        <FrameLayout
            android:background="@drawable/bg_content_browser_tabs_container"
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:clipToOutline="true">
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabContentTypes"
                android:background="@android:color/transparent"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                app:tabGravity="start"
                app:tabIndicator="@drawable/bg_content_browser_tab_indicator"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorHeight="40dp"
                app:tabMinWidth="0dp"
                app:tabMode="scrollable"
                app:tabPaddingEnd="14dp"
                app:tabPaddingStart="14dp"
                app:tabRippleColor="@android:color/transparent"
                app:tabSelectedTextColor="?attr/colorOnPrimaryContainer"
                app:tabTextAppearance="@style/TextAppearance.Material3.LabelLarge"
                app:tabTextColor="?attr/colorOnSurfaceVariant"/>
        </FrameLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutContentSearch"
            android:background="@drawable/bg_content_browser_search"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            app:boxBackgroundMode="none"
            app:endIconMode="clear_text"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_24">
            <com.google.android.material.textfield.TextInputEditText
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:id="@+id/editContentSearch"
                android:background="@android:color/transparent"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:maxLines="1"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="flagNoExtractUi|actionSearch"/>
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <com.google.android.material.button.MaterialButton
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/buttonSortContent"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:minWidth="0dp"
                android:minHeight="42dp"
                android:text="@string/content_browser_sort_downloads"
                android:layout_weight="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/buttonViewCount"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:minWidth="0dp"
                android:minHeight="42dp"
                android:text="@string/content_browser_view_count"
                android:layout_weight="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="8dp"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:ellipsize="end"
            android:gravity="end"
            android:id="@+id/textContentBrowserResultSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:overScrollMode="never">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:id="@+id/textContentBrowserVersionChip"
                    android:background="@drawable/bg_content_browser_chip"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:id="@+id/textContentBrowserLoaderChip"
                    android:background="@drawable/bg_content_browser_chip"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </HorizontalScrollView>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerContentProjects"
            android:paddingBottom="6dp"
            android:focusable="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/layoutContentPagination"
            android:paddingBottom="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPagePrevious"
                android:padding="0dp"
                android:focusable="false"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:minWidth="44dp"
                android:minHeight="40dp"
                android:contentDescription="@string/content_browser_previous_page"
                app:icon="@drawable/ic_chevron_left_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textStyle="bold"
                android:id="@+id/textPageIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPageNext"
                android:padding="0dp"
                android:focusable="false"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:minWidth="44dp"
                android:minHeight="40dp"
                android:contentDescription="@string/content_browser_next_page"
                app:icon="@drawable/ic_chevron_right_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
