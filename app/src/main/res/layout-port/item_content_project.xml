<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:focusable="false"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">
    <LinearLayout
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageProjectIcon"
                android:background="@drawable/bg_content_project_icon"
                android:padding="6dp"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:src="@drawable/ic_content_mod_24"
                android:scaleType="centerCrop"
                android:contentDescription="@string/content_browser_project_icon_description"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay_JavaLauncher_ProjectIcon"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@+id/textProjectName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:ellipsize="end"
                    android:id="@+id/textProjectAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:ellipsize="end"
            android:id="@+id/textProjectDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"/>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:ellipsize="end"
            android:id="@+id/textProjectTags"
            android:background="@drawable/bg_content_browser_chip"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_download_24"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:id="@+id/textProjectDownloads"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_favorite_24"
                android:layout_marginStart="12dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:id="@+id/textProjectLikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_history_24"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:ellipsize="end"
                android:id="@+id/textProjectUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageView
                android:id="@+id/imageProjectInstalledSource"
                android:padding="2dp"
                android:visibility="gone"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/modmanager_installed_source_icon"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/buttonInstallProject"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:minHeight="40dp"
                android:text="@string/content_browser_install"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:icon="@drawable/ic_add_24"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonProjectMenu"
                android:padding="0dp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:minWidth="40dp"
                android:minHeight="40dp"
                android:contentDescription="@string/content_browser_project_menu"
                android:layout_marginStart="6dp"
                app:icon="@drawable/ic_more_vert_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.TextButton"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
