<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollProjectDetailsRoot"
    android:background="?android:attr/colorBackground"
    android:paddingTop="10dp"
    android:paddingBottom="12dp"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardUseCompatPadding="false">
            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonProjectDetailsBack"
                        android:padding="0dp"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        android:contentDescription="Back"
                        app:icon="@drawable/ic_arrow_back_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <ImageView
                        android:id="@+id/imageProjectDetailsIcon"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="2dp"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:contentDescription="Project icon"
                        android:layout_marginStart="8dp"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:ellipsize="end"
                            android:id="@+id/textProjectDetailsTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading"
                            android:maxLines="2"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:ellipsize="end"
                            android:id="@+id/textProjectDetailsMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:maxLines="2"
                            android:lineSpacingExtra="1dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:id="@+id/textProjectDetailsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Loading"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonOpenProjectWebsite"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:minHeight="44dp"
                    android:text="Website"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabProjectDetailsSections"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            app:tabGravity="fill"
            app:tabMode="fixed"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/sectionProjectDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="false">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/imageProjectDetailsMainImage"
                        android:background="?android:attr/selectableItemBackground"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:contentDescription="Project image"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:id="@+id/textProjectDetailsDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/sectionProjectVersions"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="false">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:id="@+id/textProjectDetailsVersionFilterSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading versions..."/>
                    <TextView
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Minecraft version"/>
                    <com.google.android.material.button.MaterialButton
                        android:gravity="start|center_vertical"
                        android:id="@+id/buttonProjectDetailsMinecraftVersion"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:minHeight="44dp"
                        android:text="All Minecraft versions"
                        android:textAllCaps="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        app:icon="@drawable/ic_arrow_drop_down_24"
                        app:iconGravity="textEnd"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:gravity="center"
                        android:id="@+id/textProjectDetailsVersionPageIndicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Page 1 of 1"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonProjectDetailsVersionPrevious"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:minHeight="44dp"
                            android:text="Previous"
                            android:layout_weight="1"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonProjectDetailsVersionNext"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:minHeight="44dp"
                            android:text="Next"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProjectVersions"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/sectionProjectGallery"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/textProjectDetailsGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProjectGallery"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
