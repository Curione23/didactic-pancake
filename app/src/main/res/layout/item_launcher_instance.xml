<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/instanceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="true"
    app:strokeWidth="1dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="96dp">
        <ImageView
            android:id="@+id/imageInstanceIcon"
            android:background="@drawable/bg_instance_icon"
            android:padding="8dp"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerInside"
            android:contentDescription="@string/create_instance_select_icon"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:ellipsize="end"
                android:id="@+id/textInstanceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:ellipsize="end"
                android:id="@+id/textInstanceMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="2"/>
        </LinearLayout>
        <ImageButton
            android:id="@+id/buttonDeleteInstance"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play_arrow_24"
            android:tint="?attr/colorPrimary"
            android:contentDescription="Play instance"
            android:layout_marginStart="8dp"/>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textStyle="bold"
            android:id="@+id/textInstanceState"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/version_state_installed"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
