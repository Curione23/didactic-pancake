<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollContentBrowserRoot"
    android:background="?android:attr/colorBackground"
    android:padding="10dp"
    android:focusableInTouchMode="true"
    android:clipToPadding="false"
    android:descendantFocusability="beforeDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/layoutContentBrowserHeader"
            android:paddingTop="6dp"
            android:paddingBottom="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="fill"
                android:id="@+id/imageContentBrowserInstanceIcon"
                android:background="@drawable/bg_content_browser_instance_icon"
                android:padding="4dp"
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:contentDescription="@string/content_browser_instance_icon_description"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@+id/textContentBrowserInstanceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:ellipsize="end"
                    android:id="@+id/textContentBrowserInstanceMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBackToInstance"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:minHeight="44dp"
                android:text="@string/content_browser_back_to_instance"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="12dp"
                app:icon="@drawable/ic_arrow_back_24"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
        <View
            android:background="?attr/colorOutlineVariant"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                android:id="@+id/textContentBrowserTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/content_browser_install_title"
                android:layout_weight="1"/>
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleContentSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSourceModrinth"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:minWidth="0dp"
                    android:minHeight="42dp"
                    android:text="@string/content_browser_source_modrinth"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSourceCurseForge"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:minWidth="0dp"
                    android:minHeight="42dp"
                    android:text="@string/content_browser_source_curseforge"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <FrameLayout
                android:background="@drawable/bg_content_browser_tabs_container"
                android:padding="4dp"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:clipToOutline="true">
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabContentTypes"
                    android:background="@android:color/transparent"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    app:tabGravity="start"
                    app:tabIndicator="@drawable/bg_content_browser_tab_indicator"
                    app:tabIndicatorFullWidth="true"
                    app:tabIndicatorHeight="44dp"
                    app:tabMinWidth="0dp"
                    app:tabMode="scrollable"
                    app:tabPaddingEnd="18dp"
                    app:tabPaddingStart="18dp"
                    app:tabRippleColor="@android:color/transparent"
                    app:tabSelectedTextColor="?attr/colorOnPrimaryContainer"
                    app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall"
                    app:tabTextColor="?attr/colorOnSurfaceVariant"/>
            </FrameLayout>
        </HorizontalScrollView>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutContentSearch"
            android:background="@drawable/bg_content_browser_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_24">
            <com.google.android.material.textfield.TextInputEditText
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:id="@+id/editContentSearch"
                android:background="@android:color/transparent"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:maxLines="1"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="actionSearch"/>
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSortContent"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:minWidth="0dp"
                android:minHeight="46dp"
                android:text="@string/content_browser_sort_downloads"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonViewCount"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:minWidth="0dp"
                android:minHeight="46dp"
                android:text="@string/content_browser_view_count"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="10dp"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:ellipsize="end"
                android:id="@+id/textContentBrowserResultSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/textContentBrowserVersionChip"
                android:background="@drawable/bg_content_browser_chip"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@+id/textContentBrowserLoaderChip"
                android:background="@drawable/bg_content_browser_chip"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerContentProjects"
            android:paddingBottom="8dp"
            android:focusable="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:nestedScrollingEnabled="false"/>
        <LinearLayout
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/layoutContentPagination"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPagePrevious"
                android:padding="0dp"
                android:focusable="false"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:minWidth="48dp"
                android:minHeight="44dp"
                android:contentDescription="@string/content_browser_previous_page"
                app:icon="@drawable/ic_chevron_left_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:id="@+id/textPageIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPageNext"
                android:padding="0dp"
                android:focusable="false"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:minWidth="48dp"
                android:minHeight="44dp"
                android:contentDescription="@string/content_browser_next_page"
                app:icon="@drawable/ic_chevron_right_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
