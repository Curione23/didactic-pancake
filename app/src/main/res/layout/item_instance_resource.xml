<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardUseCompatPadding="false"
    app:strokeWidth="1dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageResourceIcon"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/instance_content_icon_description"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay_JavaLauncher_ResourceIcon"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@+id/textResourceName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/imageResourceInstalledSource"
                    android:padding="2dp"
                    android:visibility="gone"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/modmanager_installed_source_icon"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:ellipsize="end"
                android:id="@+id/textResourceSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPlayWorld"
                android:padding="0dp"
                android:visibility="gone"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="44dp"
                android:minHeight="44dp"
                android:contentDescription="@string/instance_content_play_world_button"
                app:icon="@drawable/ic_play_arrow_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonUpdateResource"
                android:padding="0dp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="44dp"
                android:minHeight="44dp"
                android:contentDescription="@string/instance_content_update_button"
                android:layout_marginStart="6dp"
                app:icon="@drawable/ic_update_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchResourceEnabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/instance_content_enable_switch"
                android:layout_marginStart="6dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDeleteResource"
                android:padding="0dp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="44dp"
                android:minHeight="44dp"
                android:contentDescription="@string/instance_content_delete_button"
                android:layout_marginStart="6dp"
                app:icon="@drawable/ic_delete_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="?attr/colorError"
                app:strokeColor="?attr/colorError"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
