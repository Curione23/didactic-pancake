<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainContent"
    android:background="?android:attr/colorBackground"
    android:padding="8dp"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainviewcardview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:strokeWidth="0dp">
        <FrameLayout
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMainTabsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/installinstanceslayout"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="10dp">
                        <TextView
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:id="@+id/textMainInstancesTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Instances"
                            android:maxLines="1"
                            android:layout_marginEnd="14dp"/>
                        <com.google.android.material.tabs.TabLayout
                            android:id="@+id/tabVersionTypes"
                            android:background="@android:color/transparent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:tabGravity="start"
                            app:tabIndicatorFullWidth="false"
                            app:tabMinWidth="66dp"
                            app:tabMode="scrollable"
                            app:tabPaddingEnd="12dp"
                            app:tabPaddingStart="12dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonStorageLocations"
                            android:padding="0dp"
                            android:layout_width="48dp"
                            android:layout_height="44dp"
                            android:minWidth="48dp"
                            android:minHeight="44dp"
                            android:text=""
                            android:contentDescription="@string/storage_locations_title"
                            app:icon="@drawable/ic_folder_24"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonRefreshVersions"
                            android:padding="0dp"
                            android:layout_width="48dp"
                            android:layout_height="44dp"
                            android:minWidth="48dp"
                            android:minHeight="44dp"
                            android:text=""
                            android:contentDescription="@string/button_refresh_versions"
                            android:layout_marginStart="8dp"
                            app:icon="@drawable/ic_refresh_24"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>
                        <Space
                            android:layout_width="8dp"
                            android:layout_height="wrap_content"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonOpenSettings"
                            android:padding="0dp"
                            android:layout_width="48dp"
                            android:layout_height="44dp"
                            android:minWidth="48dp"
                            android:minHeight="44dp"
                            android:text=""
                            android:contentDescription="@string/button_settings"
                            app:icon="@drawable/ic_settings_24"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <FrameLayout
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerVersions"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:clipToPadding="false"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="ifContentScrolls"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:nestedScrollingEnabled="true"/>
                    <ProgressBar
                        android:layout_gravity="top"
                        android:id="@+id/progressVersions"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        style="?android:attr/progressBarStyleHorizontal"/>
                    <View
                        android:layout_gravity="top"
                        android:background="@drawable/bg_main_top_content_scrim"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:importantForAccessibility="no"/>
                    <View
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_main_bottom_content_scrim"
                        android:layout_width="match_parent"
                        android:layout_height="26dp"
                        android:importantForAccessibility="no"/>
                </FrameLayout>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMainBottomActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/bottomMainActions"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <HorizontalScrollView
                                android:scrollbars="none"
                                android:clipToPadding="false"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fillViewport="false"
                                android:layout_weight="1"
                                android:overScrollMode="ifContentScrolls">
                                <LinearLayout
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content">
                                    <ImageView
                                        android:id="@+id/imageMainPlayerHead"
                                        android:background="@drawable/bg_player_head_preview"
                                        android:padding="4dp"
                                        android:focusable="true"
                                        android:clickable="true"
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:src="@drawable/ic_player_head_placeholder"
                                        android:scaleType="fitXY"
                                        android:adjustViewBounds="true"
                                        android:contentDescription="@string/main_player_head_signed_out"
                                        android:layout_marginEnd="10dp"/>
                                    <com.google.android.material.button.MaterialButton
                                        android:textStyle="bold"
                                        android:id="@+id/buttonShareLatestLog"
                                        android:padding="8dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="44dp"
                                        android:minWidth="48dp"
                                        android:minHeight="44dp"
                                        android:text="Share Logs"
                                        android:contentDescription="@string/button_share_latest_log"
                                        app:icon="@drawable/ic_share_24"
                                        app:iconGravity="textStart"
                                        app:iconPadding="0dp"
                                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                                    <Space
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"/>
                                    <com.google.android.material.button.MaterialButton
                                        android:ellipsize="end"
                                        android:id="@+id/buttonBrowseContentMain"
                                        android:layout_width="wrap_content"
                                        android:layout_height="44dp"
                                        android:minWidth="132dp"
                                        android:minHeight="44dp"
                                        android:text="Browse Modpacks"
                                        android:maxLines="1"
                                        app:icon="@drawable/ic_browse_modpacks_24"
                                        app:iconGravity="textStart"
                                        app:iconPadding="8dp"
                                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                                    <Space
                                        android:layout_width="8dp"
                                        android:layout_height="wrap_content"/>
                                    <com.google.android.material.button.MaterialButton
                                        android:ellipsize="end"
                                        android:id="@+id/buttonImportModpackMain"
                                        android:layout_width="wrap_content"
                                        android:layout_height="44dp"
                                        android:minWidth="126dp"
                                        android:minHeight="44dp"
                                        android:text="Import Modpack"
                                        android:maxLines="1"
                                        app:icon="@drawable/ic_import_modpack_24"
                                        app:iconGravity="textStart"
                                        app:iconPadding="8dp"
                                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                                </LinearLayout>
                            </HorizontalScrollView>
                            <Space
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"/>
                            <com.google.android.material.floatingactionbutton.FloatingActionButton
                                android:id="@+id/fabCreateInstance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:contentDescription="@string/create_instance_button"
                                app:borderWidth="1dp"
                                app:fabSize="mini"
                                app:srcCompat="@drawable/ic_add_24"/>
                        </LinearLayout>
                        <TextView
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:ellipsize="end"
                            android:id="@+id/textStatus"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:maxLines="2"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp">
        <TextView
            android:id="@+id/textVersionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""/>
        <TextView
            android:id="@+id/textSelectedVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selected_instance_empty"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLaunchVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_launch_version"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenFolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_open_folder"/>
        <TextView
            android:id="@+id/textAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"/>
        <TextView
            android:id="@+id/textAccountStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_signed_out"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSignIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_sign_in"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSignOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_sign_out"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchShowSharedInstalls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/textSharedInstallsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/textFolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/textRenderSurfaceTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchUseNativeSurface"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/textRenderSurfaceSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <CheckBox
            android:id="@+id/checkKeepLogs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</FrameLayout>
