<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInstanceHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardUseCompatPadding="true">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBackFromInstanceDetails"
                android:padding="0dp"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:minWidth="46dp"
                android:minHeight="46dp"
                android:contentDescription="@android:string/cancel"
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.TextButton.Icon"/>
            <ImageView
                android:id="@+id/imageInstanceIcon"
                android:background="@drawable/bg_instance_icon"
                android:padding="7dp"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerInside"
                android:contentDescription="@string/create_instance_select_icon"
                android:layout_marginStart="8dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@+id/textInstanceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:ellipsize="end"
                    android:id="@+id/textInstanceMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPlay"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:minWidth="0dp"
                android:minHeight="46dp"
                android:text="@string/button_play_instance"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:layout_marginStart="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonInstanceSettings"
                android:padding="0dp"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:minWidth="46dp"
                android:minHeight="46dp"
                android:contentDescription="@string/instance_settings_content_description"
                android:layout_marginStart="8dp"
                app:icon="@drawable/ic_settings_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/instance_details_content_title"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="12dp"/>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:ellipsize="end"
            android:id="@+id/textModsHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_weight="1"/>
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBrowseContent"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:minHeight="40dp"
                    android:text="@string/button_browse_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="14dp"
                    app:icon="@drawable/ic_browse_content_24"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAddMods"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:minHeight="40dp"
                    android:text="@string/button_upload_mods"
                    android:paddingStart="12dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCheckContentUpdates"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:minHeight="40dp"
                    android:text="@string/instance_content_check_updates"
                    android:paddingStart="12dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_sync_24"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonUpdateAllContent"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:minHeight="40dp"
                    android:text="@string/instance_content_update_all"
                    android:paddingStart="12dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_update_24"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layoutContentControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <ca.dnamobile.javalauncher.ui.view.RoundedClipFrameLayout
            android:id="@+id/layoutResourceCategoryTabs"
            android:background="@drawable/bg_content_tab_container"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp">
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabResourceCategories"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:tabGravity="start"
                app:tabIndicator="@drawable/bg_content_tab_indicator"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorHeight="48dp"
                app:tabMinWidth="96dp"
                app:tabMode="scrollable"
                app:tabPaddingEnd="22dp"
                app:tabPaddingStart="22dp"
                app:tabRippleColor="@android:color/transparent"
                app:tabSelectedTextColor="?attr/colorOnPrimaryContainer"
                app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall"
                app:tabTextColor="?attr/colorOnSurfaceVariant"/>
        </ca.dnamobile.javalauncher.ui.view.RoundedClipFrameLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutContentSearch"
            android:layout_width="260dp"
            android:layout_height="50dp"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:endIconMode="clear_text"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_24"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextContentSearch"
                android:background="@android:color/transparent"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Search content"
                android:maxLines="1"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="flagNoExtractUi|actionDone"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResourceItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        app:cardCornerRadius="20dp"
        app:cardUseCompatPadding="true">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerResourceItems"
            android:padding="8dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="ifContentScrolls"
            android:nestedScrollingEnabled="true"/>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
